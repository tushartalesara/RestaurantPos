{
  "cli": {
    "version": ">= 16.13.0"
  },
  "build": {
    "preview": {
      "environment": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "ios-simulator": {
      "environment": "preview",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "environment": "production",
      "autoIncrement": true
    }
  }
}
